<?xml version="1.0" encoding="utf-8"?>
<!--
    Hermes Hub deve raggiungere gateway personali configurabili su Tailnet/LAN, spesso
    esposti in HTTP tramite MagicDNS o IP privato. Il cleartext resta quindi abilitato;
    quando il gateway configurato offre HTTPS, il client usa comunque quell'URL.
-->
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <base-config
        cleartextTrafficPermitted="true"
        tools:ignore="InsecureBaseConfiguration">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
