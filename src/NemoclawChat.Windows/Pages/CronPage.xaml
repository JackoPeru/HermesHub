<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NemoclawChat_Windows.Pages.CronPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Padding="44,36">
            <StackPanel MaxWidth="1080" HorizontalAlignment="Left" Spacing="22">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontSize="30"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Cron" />
                        <TextBlock
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Automazioni Hermes realmente programmate sul gateway. Per crearne una nuova, chiedilo in chat: Hermes usera' il proprio tool cron ufficiale." />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        MinWidth="110"
                        Click="Refresh_Click"
                        Content="Aggiorna" />
                </Grid>

                <Border
                    Padding="18"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#FF3A3A3A"
                    BorderThickness="1"
                    CornerRadius="18">
                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Name="StatusText"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Caricamento cron..." />
                        <TextBlock
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="Fonte: GET /api/jobs?type=cron&amp;include_disabled=1. I cron in pausa restano visibili, ma separati dagli attivi."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel x:Name="CronPanel" Spacing="14" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
